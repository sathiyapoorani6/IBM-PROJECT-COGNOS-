document.addEventListener('DOMContentLoaded', function() {
    // Initialize dashboard components
    initDashboard();
    
    // Handle filter application
    const applyBtn = document.querySelector('.btn-apply');
    if (applyBtn) {
        applyBtn.addEventListener('click', applyFilters);
    }
});

function initDashboard() {
    // You can add any dashboard initialization logic here
    console.log('Dashboard initialized');
    
    // Example: Set default filter values from URL params
    const urlParams = new URLSearchParams(window.location.search);
    const timePeriod = urlParams.get('timePeriod');
    const region = urlParams.get('region');
    
    if (timePeriod) {
        document.getElementById('timePeriod').value = timePeriod;
    }
    
    if (region) {
        document.getElementById('region').value = region;
    }
}

function applyFilters() {
    const timePeriod = document.getElementById('timePeriod').value;
    const region = document.getElementById('region').value;
    
    // Update the iframe URL with new filters
    const iframe = document.querySelector('.dashboard-embed iframe');
    if (iframe) {
        const currentUrl = new URL(iframe.src);
        
        // Update URL parameters (this is a simulation - actual Cognos parameters may differ)
        currentUrl.searchParams.set('timePeriod', timePeriod);
        currentUrl.searchParams.set('region', region);
        
        // Reload iframe with new parameters
        iframe.src = currentUrl.toString();
    }
    
    // Update browser URL (without reload)
    const newUrl = new URL(window.location);
    newUrl.searchParams.set('timePeriod', timePeriod);
    newUrl.searchParams.set('region', region);
    window.history.pushState({}, '', newUrl);
    
    // Show notification
    showNotification('Filters applied successfully');
}

function showNotification(message, type = 'success') {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
    notification.textContent = message;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.classList.add('fade-out');
        setTimeout(() => notification.remove(), 300);
    }, 3000);
}

