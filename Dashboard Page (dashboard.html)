<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IBM Cognos Analytics - Dashboard</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <img src="https://www.ibm.com/brand/experience-guides/developer/b1db1ae501d522a1a4b49613fe07c9f1/01_8-bar-positive.svg" alt="IBM Logo" class="logo">
                <h2>Cognos Analytics</h2>
            </div>
            
            <nav class="sidebar-nav">
                <ul>
                    <li class="active"><a href="#"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                    <li><a href="#"><i class="fas fa-chart-bar"></i> Reports</a></li>
                    <li><a href="#"><i class="fas fa-database"></i> Data Modules</a></li>
                    <li><a href="#"><i class="fas fa-cog"></i> Administration</a></li>
                    <li><a href="#"><i class="fas fa-question-circle"></i> Help</a></li>
                </ul>
            </nav>
            
            <div class="sidebar-footer">
                <div class="user-profile">
                    <img src="https://via.placeholder.com/40" alt="User" class="user-avatar">
                    <div class="user-info">
                        <span class="username">John Doe</span>
                        <span class="user-role">Administrator</span>
                    </div>
                    <a href="#" id="logoutBtn"><i class="fas fa-sign-out-alt"></i></a>
                </div>
            </div>
        </aside>
        
        <!-- Main Content Area -->
        <main class="main-content">
            <header class="main-header">
                <h1>Project Q5 Dashboard</h1>
                <div class="header-actions">
                    <button class="btn btn-primary"><i class="fas fa-plus"></i> New Report</button>
                    <button class="btn btn-secondary"><i class="fas fa-share-alt"></i> Share</button>
                </div>
            </header>
            
            <div class="content-area">
                <!-- Dashboard Filters -->
                <div class="dashboard-filters">
                    <div class="filter-group">
                        <label for="timePeriod">Time Period:</label>
                        <select id="timePeriod">
                            <option>Last 7 Days</option>
                            <option>Last 30 Days</option>
                            <option>Last Quarter</option>
                            <option>Last Year</option>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="region">Region:</label>
                        <select id="region">
                            <option>All Regions</option>
                            <option>North America</option>
                            <option>Europe</option>
                            <option>Asia</option>
                        </select>
                    </div>
                    
                    <button class="btn btn-apply">Apply Filters</button>
                </div>
                
                <!-- Embedded IBM Cognos Dashboard -->
                <div class="dashboard-embed">
                    <iframe 
                        src="https://ap2.ca.analytics.ibm.com/bi/?perspective=dashboard&pathRef=.my_folders%2FPROJECT%2BQ5%25281%2529&closeWindowOnLastView=true&ui_appbar=false&ui_navbar=false&shareMode=embedded&action=view&mode=dashboard&subView=model0000019d7344af0a_00000000&nav_filter=true" 
                        frameborder="0" 
                        allowfullscreen>
                    </iframe>
                </div>
                
                <!-- Dashboard Widgets -->
                <div class="dashboard-widgets">
                    <div class="widget">
                        <h3>Key Metrics</h3>
                        <div class="metric-container">
                            <div class="metric">
                                <span class="metric-value">1,245</span>
                                <span class="metric-label">Total Users</span>
                            </div>
                            <div class="metric">
                                <span class="metric-value">$48,752</span>
                                <span class="metric-label">Revenue</span>
                            </div>
                            <div class="metric">
                                <span class="metric-value">78%</span>
                                <span class="metric-label">Engagement</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="widget">
                        <h3>Recent Activity</h3>
                        <ul class="activity-list">
                            <li>
                                <i class="fas fa-file-alt activity-icon"></i>
                                <div class="activity-details">
                                    <span class="activity-title">New report created</span>
                                    <span class="activity-time">2 hours ago</span>
                                </div>
                            </li>
                            <li>
                                <i class="fas fa-user-edit activity-icon"></i>
                                <div class="activity-details">
                                    <span class="activity-title">User permissions updated</span>
                                    <span class="activity-time">5 hours ago</span>
                                </div>
                            </li>
                            <li>
                                <i class="fas fa-share-alt activity-icon"></i>
                                <div class="activity-details">
                                    <span class="activity-title">Dashboard shared</span>
                                    <span class="activity-time">Yesterday</span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="auth.js"></script>
    <script src="dashboard.js"></script>
</body>
</html>
